generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String
  fullName     String        @default("")
  email        String        @default("")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  roles        UserRole[]
  certificates      Certificate[]    @relation("IssuedBy")
  applications      Application[]    @relation("AssignedTo")
  rejectionLetters  RejectionLetter[] @relation("RejectedBy")
}

model UserRole {
  id     Int    @id @default(autoincrement())
  userId Int
  role   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TelegramConnect {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  chatId    String?
  username  String?
  connected Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Application {
  id               Int               @id @default(autoincrement())
  userType         String
  fullName         String?
  orgName          String?
  phone            String
  email            String
  branchRequest    Boolean           @default(false)
  notifyMethod     String            @default("email")
  telegramChatId   String?
  devices          String            @default("[]")
  filePath         String?
  status           String            @default("new")
  assignedToId     Int?
  assignedTo       User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  certificate      Certificate?
  rejectionLetter  RejectionLetter?
  createdAt        DateTime          @default(now())
}

model RejectionLetter {
  id            Int         @id @default(autoincrement())
  applicationId Int         @unique
  application   Application @relation(fields: [applicationId], references: [id])
  reason        String
  letterText    String
  createdById   Int
  createdBy     User        @relation("RejectedBy", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
}

model Certificate {
  id            Int         @id @default(autoincrement())
  certNumber    String      @unique
  applicationId Int         @unique
  application   Application @relation(fields: [applicationId], references: [id])
  issuedById    Int
  issuedBy      User        @relation("IssuedBy", fields: [issuedById], references: [id])
  issuedAt      DateTime    @default(now())
  expiresAt     DateTime
  filePath      String?
  notes         String?
  status        String      @default("active")
  createdAt     DateTime    @default(now())
}

model Region {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  districts District[]
}

model District {
  id       Int    @id @default(autoincrement())
  name     String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  regionId Int
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  titleUz     String
  titleRu     String
  titleEn     String
  excerptUz   String
  excerptRu   String
  excerptEn   String
  contentUz   String   @default("")
  contentRu   String   @default("")
  contentEn   String   @default("")
  category    String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
